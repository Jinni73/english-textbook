{
  "id": "relative-clauses",
  "bookId": "grade-9",
  "title": "Relative Clauses",
  "titleZh": "关系从句（定语从句）",
  "order": 3,
  "summary": "A relative clause modifies a noun (the antecedent). Restrictive relative clauses use that, which, or who.",
  "summaryZh": "关系从句修饰名词（先行词）。限定性关系从句常用 that、which、who 引导。",
  "lessons": [
    {
      "id": "relative-concept",
      "type": "concept",
      "title": "What is a relative clause?",
      "titleZh": "什么是关系从句",
      "bodyZh": "关系从句放在被修饰的名词之后，说明“什么样的”。先行词是被修饰的名词；关系代词 that / which / who 在从句中可作主语或宾语。",
      "examples": [
        {
          "text": "I like musicians who are creative.",
          "noteZh": "先行词 musicians，who 指人"
        },
        {
          "text": "I prefer music that touches me.",
          "noteZh": "先行词 music，that 指物"
        }
      ]
    },
    {
      "id": "relative-formation",
      "type": "formation",
      "title": "Relative pronouns",
      "titleZh": "关系代词",
      "pronounTable": [
        {
          "pronoun": "that",
          "refersToZh": "指人或指物",
          "asSubject": "I prefer music that touches me.",
          "asObject": "That's the only thing (that) I can do now.",
          "objectOmittable": true
        },
        {
          "pronoun": "which",
          "refersToZh": "指物",
          "asSubject": "The song which uses the violin and the erhu is my favourite.",
          "asObject": "He is listening to the music (which) he downloaded just now.",
          "objectOmittable": true
        },
        {
          "pronoun": "who",
          "refersToZh": "指人",
          "asSubject": "He is the kind of man who never gives up.",
          "asObject": "The man (who) we met at the library is our new teacher.",
          "objectOmittable": true
        }
      ],
      "noteZh": "非正式语境中，关系代词作宾语时常可省略。"
    },
    {
      "id": "relative-usage",
      "type": "usage",
      "title": "Subject vs object",
      "titleZh": "作主语与作宾语",
      "rules": [
        {
          "textZh": "关系代词在从句中作主语时不可省略。",
          "textEn": "Do not omit the pronoun when it is the subject of the clause."
        },
        {
          "textZh": "关系代词在从句中作宾语时，口语中常省略。",
          "textEn": "The pronoun is often omitted when it is the object."
        }
      ]
    }
  ],
  "examples": [
    {
      "id": "rc-ex-01",
      "text": "I love traditional music that tells a story.",
      "highlight": "that tells a story",
      "noteZh": "that 作主语",
      "unitRef": {
        "unit": 7
      }
    },
    {
      "id": "rc-ex-02",
      "text": "I like musicians who are creative.",
      "highlight": "who are creative",
      "noteZh": "who 指人",
      "unitRef": {
        "unit": 7
      }
    },
    {
      "id": "rc-ex-03",
      "text": "It's a piece which everyone loves!",
      "highlight": "which everyone loves",
      "noteZh": "which 作宾语",
      "unitRef": {
        "unit": 7
      }
    },
    {
      "id": "rc-ex-04",
      "text": "They are looking for somebody who can join the relay.",
      "highlight": "who can join the relay",
      "noteZh": "Unit 8 听力",
      "unitRef": {
        "unit": 8
      }
    }
  ],
