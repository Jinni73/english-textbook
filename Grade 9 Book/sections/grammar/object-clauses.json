{
  "id": "object-clauses",
  "bookId": "grade-9",
  "title": "Object Clauses",
  "titleZh": "宾语从句",
  "order": 2,
  "summary": "An object clause functions as the object in a complex sentence. Common conjunctions include that, if, whether, and wh- words.",
  "summaryZh": "宾语从句在复合句中作宾语。常见关联词有 that、if、whether 以及 what、who、when 等疑问词。",
  "lessons": [
    {
      "id": "object-concept",
      "type": "concept",
      "title": "What is an object clause?",
      "titleZh": "什么是宾语从句",
      "bodyZh": "宾语从句放在及物动词或介词之后，说明“什么”或“是否”。从句要用陈述语序，不用疑问语序。",
      "examples": [
        {
          "text": "I believe (that) reading is important.",
          "noteZh": "that 可省略"
        },
        {
          "text": "Can you tell me who she is?",
          "noteZh": "陈述语序 who she is，不说 who is she"
        }
      ]
    },
    {
      "id": "object-formation",
      "type": "formation",
      "title": "Common conjunctions",
      "titleZh": "常见关联词",
      "conjunctionGroups": [
        {
          "labelZh": "that（口语中常省略）",
          "conjunctions": [
            "that"
          ],
          "examples": [
            "Mary thinks (that) the teams were just fantastic.",
            "I believe (that) reading is important for learning."
          ]
        },
        {
          "labelZh": "if / whether（口语中 if 更常见）",
          "conjunctions": [
            "if",
            "whether"
          ],
          "examples": [
            "I wonder if / whether there will be races again next year.",
            "I want to know whether you read English books outside class."
          ]
        },
        {
          "labelZh": "who, what, which, when, where, how, why",
          "conjunctions": [
            "who",
            "what",
            "which",
            "when",
            "where",
            "how",
            "why"
          ],
          "examples": [
            "Can you tell me who she is?",
            "He cannot remember what he ate for breakfast.",
            "I want to know how memory works."
          ]
        }
      ]
    },
    {
      "id": "object-usage",
      "type": "usage",
      "title": "Word order",
      "titleZh": "语序要点",
      "rules": [
        {
          "textZh": "宾语从句用陈述语序：who she is ✓，who is she ✗",
          "textEn": "Use statement word order inside the clause."
        },
        {
          "textZh": "that 在口语或非正式文体中常省略。",
          "textEn": "that is often omitted in spoken or informal English."
        }
      ]
    }
  ],
  "examples": [
    {
      "id": "oc-ex-01",
      "text": "I wonder if you could help me with my history study.",
      "highlight": "if you could help me with my history study",
      "noteZh": "if 引导宾语从句",
      "unitRef": {
        "unit": 3
      }
    },
    {
      "id": "oc-ex-02",
      "text": "I want to know whether you read English books outside class.",
      "highlight": "whether you read English books outside class",
      "noteZh": "whether 引导",
      "unitRef": {
        "unit": 3
      }
    },
    {
      "id": "oc-ex-03",
      "text": "I want to know how memory works.",
      "highlight": "how memory works",
      "noteZh": "how + 陈述语序",
      "unitRef": {
        "unit": 4
      }
    },
    {
      "id": "oc-ex-04",
      "text": "I don't know why I am so forgetful.",
      "highlight": "why I am so forgetful",
      "noteZh": "why 引导",
      "unitRef": {
        "unit": 4
      }
    }
  ],
