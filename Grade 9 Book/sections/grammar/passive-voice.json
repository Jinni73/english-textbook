{
  "id": "passive-voice",
  "bookId": "grade-9",
  "title": "Passive Voice",
  "titleZh": "被动语态",
  "order": 1,
  "summary": "When the subject receives the action, use the passive voice: auxiliary be + past participle of a transitive verb.",
  "summaryZh": "主语是动作的承受者时用被动语态：助动词 be + 及物动词的过去分词。",
  "lessons": [
    {
      "id": "passive-concept",
      "type": "concept",
      "title": "Active vs Passive",
      "titleZh": "主动语态和被动语态",
      "bodyZh": "英语动词有两种语态。主动语态中主语是动作的执行者；被动语态中主语是动作的承受者。",
      "pairs": [
        {
          "active": "Many people speak English.",
          "passive": "English is spoken by many people.",
          "noteZh": "执行者 many people → 承受者 English"
        },
        {
          "active": "Alexander Bell invented the telephone in 1876.",
          "passive": "The telephone was invented by Alexander Bell in 1876.",
          "noteZh": "执行者 Alexander Bell → 承受者 The telephone"
        }
      ]
    },
    {
      "id": "passive-formation",
      "type": "formation",
      "title": "How to form the passive",
      "titleZh": "被动语态的构成",
      "formula": "be + past participle",
      "formulaZh": "助动词 be + 及物动词的过去分词（-ed 形式）",
      "noteZh": "助动词 be 随人称、数和时态变化。",
      "tenseTable": {
        "verb": "ask",
        "rows": [
          {
            "tenseZh": "一般现在时",
            "affirmative": "I am asked … / He is asked … / They are asked …",
            "negative": "I am not asked … / He is not asked …",
            "interrogative": "Am I asked …? / Is he asked …?"
          },
          {
            "tenseZh": "一般过去时",
            "affirmative": "I was asked … / He was asked … / They were asked …",
            "negative": "I was not asked …",
            "interrogative": "Was I asked …? / Were they asked …?"
          },
          {
            "tenseZh": "一般将来时",
            "affirmative": "I / He / They will be asked …",
            "negative": "… will not be asked …",
            "interrogative": "Will I / he / they be asked …?"
          }
        ]
      }
    },
    {
      "id": "passive-usage",
      "type": "usage",
      "title": "When to use the passive",
      "titleZh": "被动语态的用法",
      "rules": [
        {
          "textZh": "不知道或不必说明动作执行者时，或需要强调动作的承受者时。",
          "textEn": "When the doer is unknown or unnecessary, or when the receiver needs emphasis."
        },
        {
          "textZh": "科技报道、新闻等正式文体中更常见，有助于篇章衔接。",
          "textEn": "Common in formal writing such as science and news reports."
        }
      ]
    }
  ],
  "examples": [
    {
      "id": "pv-ex-01",
      "text": "A mini-camera is connected to the front of the glasses.",
      "highlight": "is connected to",
      "noteZh": "一般现在时被动",
      "unitRef": {
        "unit": 5
      }
    },
    {
      "id": "pv-ex-02",
      "text": "Some of the old buildings were destroyed in the earthquake.",
      "highlight": "were destroyed",
      "noteZh": "一般过去时被动"
    },
    {
      "id": "pv-ex-03",
      "text": "More astronauts will be sent to the space station.",
      "highlight": "will be sent to",
      "noteZh": "一般将来时被动",
      "unitRef": {
        "unit": 6
      }
    },
    {
      "id": "pv-ex-04",
      "text": "The moon will be visited by tourists one day.",
      "highlight": "will be visited by",
      "noteZh": "强调承受者 the moon"
    }
  ],
